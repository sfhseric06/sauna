#!/bin/bash
# =============================================================================
# CLOUD SECRETS — EXAMPLE
# =============================================================================
# Copy this file to cloud/secrets.sh and fill in real values.
# cloud/secrets.sh is gitignored and never committed.
#
#   cp cloud/secrets.sh.example cloud/secrets.sh
#   $EDITOR cloud/secrets.sh
# =============================================================================

# Shelly Cloud auth key (from home.shelly.cloud → Settings → Authorization cloud key)
SHELLY_AUTH_KEY="your-shelly-auth-key"

# Twilio auth token (from console.twilio.com → Account Info)
TWILIO_AUTH_TOKEN="your-twilio-auth-token"

# Shared secret between Worker and primary Shelly script.
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET="generate-with-openssl-rand-hex-32"

# Grafana Cloud API key with MetricsPublisher role.
# From Grafana Cloud → your stack → "Send metrics" → Prometheus → Password/API key.
GRAFANA_API_KEY="your-grafana-api-key"

# Authorized SMS users — E.164 number:Name pairs, comma-separated.
# Kept here (gitignored) because phone numbers are personal data.
AUTHORIZED_USERS="+1XXXXXXXXXX:Name,+1XXXXXXXXXX:Name"
