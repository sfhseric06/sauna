{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Select your Grafana Cloud Prometheus data source",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "state-timeline",
      "name": "State timeline",
      "version": ""
    },
    {
      "type": "panel",
      "id": "gauge",
      "name": "Gauge",
      "version": ""
    }
  ],
  "title": "Sauna",
  "uid": "sauna-v1",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "tags": ["sauna"],
  "timezone": "browser",
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "graphTooltip": 1,
  "annotations": { "list": [] },
  "links": [],
  "templating": { "list": [] },
  "panels": [

    {
      "id": 1,
      "type": "timeseries",
      "title": "Temperature",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "sauna_temperature_fahrenheit{sensor=\"indoor\"}",  "legendFormat": "Indoor"  },
        { "refId": "B", "expr": "sauna_temperature_fahrenheit{sensor=\"outdoor\"}", "legendFormat": "Outdoor" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "fahrenheit",
          "custom": { "lineWidth": 2, "fillOpacity": 8, "spanNulls": true },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue",   "value": null },
              { "color": "orange", "value": 150  },
              { "color": "red",    "value": 190  }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Outdoor" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [6, 4], "fill": "dash" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 2,
      "type": "gauge",
      "title": "Indoor Temp",
      "gridPos": { "x": 0, "y": 8, "w": 5, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "sauna_temperature_fahrenheit{sensor=\"indoor\"}", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "fahrenheit",
          "min": 0,
          "max": 220,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "#1c4e80" },
              { "value": 50,   "color": "#1F60C4" },
              { "value": 80,   "color": "#5794F2" },
              { "value": 110,  "color": "#73BF69" },
              { "value": 140,  "color": "#FADE2A" },
              { "value": 165,  "color": "#FF9830" },
              { "value": 185,  "color": "#F2495C" },
              { "value": 205,  "color": "#C4162A" }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto"
      }
    },

    {
      "id": 3,
      "type": "gauge",
      "title": "Outdoor Temp",
      "gridPos": { "x": 5, "y": 8, "w": 5, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "sauna_temperature_fahrenheit{sensor=\"outdoor\"}", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "fahrenheit",
          "min": -20,
          "max": 120,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "#1c4e80" },
              { "value": 0,    "color": "#1F60C4" },
              { "value": 32,   "color": "#5794F2" },
              { "value": 50,   "color": "#73BF69" },
              { "value": 70,   "color": "#FADE2A" },
              { "value": 85,   "color": "#FF9830" },
              { "value": 100,  "color": "#F2495C" },
              { "value": 110,  "color": "#C4162A" }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto"
      }
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Sauna",
      "gridPos": { "x": 10, "y": 8, "w": 7, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "sauna_relay_on{name=\"heater_contactor\"}", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "OFF", "color": "semi-dark-gray",   "index": 0 },
                "1": { "text": "ON",  "color": "semi-dark-orange", "index": 1 }
              }
            }
          ],
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "gray",   "value": null },
              { "color": "orange", "value": 1    }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "background"
      }
    },

    {
      "id": 5,
      "type": "stat",
      "title": "Time Remaining",
      "gridPos": { "x": 17, "y": 8, "w": 7, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "sauna_remaining_seconds{device=\"primary\"}", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "gray",   "value": null },
              { "color": "red",    "value": 1    },
              { "color": "orange", "value": 600  },
              { "color": "green",  "value": 1800 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "value"
      }
    },

    {
      "id": 12,
      "type": "stat",
      "title": "Total Sessions",
      "gridPos": { "x": 10, "y": 11, "w": 14, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "sauna_sessions_total", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "unit": "short",
          "decimals": 0
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "background"
      }
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "Power Draw",
      "gridPos": { "x": 0, "y": 14, "w": 16, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "sauna_power_watts{device=\"primary\", name=\"heater\"}", "legendFormat": "Heater (inferred)"  },
        { "refId": "B", "expr": "sauna_power_watts{device=\"hvac\"}",                    "legendFormat": "HVAC Ch{{channel}}" },
        { "refId": "C", "expr": "sauna_power_watts{device=\"exterior\"}",                "legendFormat": "Exterior Light"     }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "custom": { "lineWidth": 1, "fillOpacity": 12, "spanNulls": true },
          "color": { "mode": "palette-classic" },
          "min": 0
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "HVAC.*|LED Strip|Exterior Light" },
            "properties": [
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "custom.axisLabel",     "value": "Accessories (W)" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Heater" },
            "properties": [
              { "id": "custom.axisLabel", "value": "Heater (W)" }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 8,
      "type": "stat",
      "title": "Heater Power",
      "gridPos": { "x": 16, "y": 14, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "sauna_power_watts{device=\"primary\", name=\"heater\"}", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "gray",   "value": null },
              { "color": "orange", "value": 100  },
              { "color": "red",    "value": 4000 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "background"
      }
    },

    {
      "id": 9,
      "type": "stat",
      "title": "HVAC Power",
      "gridPos": { "x": 16, "y": 18, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "sum(sauna_power_watts{device=\"hvac\"})", "instant": true, "legendFormat": "HVAC" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "gray",   "value": null },
              { "color": "blue",   "value": 10   },
              { "color": "orange", "value": 500  }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "background"
      }
    },

    {
      "id": 10,
      "type": "state-timeline",
      "title": "Device States",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "sauna_relay_on{name=\"heater_contactor\"}", "legendFormat": "Heater Relay"   },
        { "refId": "B", "expr": "sauna_relay_on{name=\"safety_contactor\"}", "legendFormat": "Safety Relay"   },
        { "refId": "C", "expr": "sauna_relay_on{name=\"exterior_light\"}",   "legendFormat": "Exterior Light" },
        { "refId": "D", "expr": "sauna_relay_on{name=\"led_strip\"}",        "legendFormat": "LED Strip"      },
        { "refId": "E", "expr": "sauna_relay_on{name=\"hvac_0\"}",           "legendFormat": "HVAC Ch0"       },
        { "refId": "F", "expr": "sauna_relay_on{name=\"hvac_1\"}",           "legendFormat": "HVAC Ch1"       }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "range",
              "options": { "from": -0.5, "to": 0.5, "result": { "text": "OFF", "color": "gray",  "index": 0 } }
            },
            {
              "type": "range",
              "options": { "from": 0.5,  "to": 1.5, "result": { "text": "ON",  "color": "green", "index": 1 } }
            }
          ],
          "color": { "mode": "fixed", "fixedColor": "gray" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "gray", "value": null }]
          },
          "custom": { "fillOpacity": 85, "lineWidth": 0 }
        }
      },
      "options": {
        "mergeValues": true,
        "rowHeight": 0.8,
        "showValue": "always",
        "alignValue": "center",
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 13,
      "type": "timeseries",
      "title": "Energy Over Time",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "sauna_energy_kwh_total", "legendFormat": "All-time kWh"    },
        { "refId": "B", "expr": "sauna_energy_kwh_month", "legendFormat": "This month kWh"  }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "custom": { "lineWidth": 2, "fillOpacity": 15, "spanNulls": true },
          "color": { "mode": "palette-classic" },
          "min": 0
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 14,
      "type": "stat",
      "title": "Total Energy",
      "gridPos": { "x": 12, "y": 28, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "sauna_energy_kwh_total", "instant": true, "legendFormat": "All-time" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "decimals": 1,
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "orange", "value": null }]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "background"
      }
    },

    {
      "id": 15,
      "type": "stat",
      "title": "Energy This Month",
      "gridPos": { "x": 18, "y": 28, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "sauna_energy_kwh_month", "instant": true, "legendFormat": "Month kWh" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "decimals": 1,
          "color": { "mode": "fixed", "fixedColor": "semi-dark-orange" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "semi-dark-orange", "value": null }]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "background"
      }
    }

  ]
}
